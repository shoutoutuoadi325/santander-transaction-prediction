\f4\fs26 \cf0 def train_lightgbm(X_train, y_train, X_valid, y_valid):\
    model = LGBMClassifier(\
        n_estimators=2000,\
        learning_rate=0.01,\
        num_leaves=31,\
        subsample=0.8,\
        colsample_bytree=0.8,\
        class_weight="balanced",\
        random_state=42\
    )\
\
    model.fit(\
        X_train, y_train,\
        eval_set=[(X_valid, y_valid)],\
        eval_metric="auc"\
    )\
\
    return model\
